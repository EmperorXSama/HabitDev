name: dockercompose11103496234646683144
services:
  habitdev:
    build:
      context: C:\Users\khali\RiderProjects\HabitDev
      dockerfile: HabitDev/Dockerfile
    environment:
      ASPNETCORE_ENVIRONMENT: Development
      ASPNETCORE_HTTP_PORTS: "8080"
      ASPNETCORE_HTTPS_PORTS: "8081"
    image: habitdev
    networks:
      default: null
    ports:
      - mode: ingress
        target: 8080
        protocol: tcp
      - mode: ingress
        target: 8081
